# findmyminers - Environment Variables
# Copy this file to .env.local and fill in the values.

# ──────────────── Agent ────────────────
# Shared key for authenticating the Windows polling agent.
AGENT_SHARED_KEY=change-me-to-a-random-secret

# ──────────────── Alerts ────────────────
# Discord webhook URL for alert notifications (optional)
ALERT_WEBHOOK_URL=

# Telegram bot token and chat ID for alert notifications (optional)
ALERT_TELEGRAM_BOT_TOKEN=
ALERT_TELEGRAM_CHAT_ID=

# Temperature threshold in °C (default: 90)
ALERT_TEMP_THRESHOLD_C=90

# Hashrate drop ratio — alert if current < avg * ratio (default: 0.7)
ALERT_HASHRATE_DROP_RATIO=0.7

# ──────────────── Profitability ────────────────
# Electricity cost in EUR per kWh (default: 0.25)
ELEC_COST_EUR_KWH=0.25

# Pool fee percentage (default: 2)
POOL_FEE_PCT=2

# ──────────────── Self-hosted / Local mode ────────────────
# Set to 1 to skip login on your own LAN dashboard (serves your REAL miners).
# Recommended for a quick local test. Leave unset for multi-user deployments.
LOCAL_MODE=1

# ──────────────── Application ────────────────
NODE_ENV=development
