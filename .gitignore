# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — keep secrets out, but ship the template
.env*
!.env.example

# runtime data — contains secrets (auth hashes, VAPID private key),
# telemetry history and the SQLite database. NEVER commit this.
/data/*
!/data/.gitkeep

# agent runtime config (holds the shared key) and builds
agent/**/agent-config.json
agent/**/node_modules
agent/**/dist
agent/**/release

# build Windows portable
/release/

# sauvegardes éditeur
*.bak

# outillage IA / éditeur personnel — hors distribution
/superpowers/
/.agents/
/.aidesigner/
/.claude/
/.github/skills/
/.vscode/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.aidesigner/*
!.aidesigner/.gitkeep
