{
  "name": "findmyminers-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Local-network agent for discovering miners and pushing telemetry to FindMyMiners dashboard",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "build:win": "pkg src/index.js --targets node18-win-x64 --output dist/findmyminers-agent.exe",
    "build:linux": "pkg src/index.js --targets node18-linux-x64 --output dist/findmyminers-agent-linux-x64",
    "build:arm64": "pkg src/index.js --targets node18-linux-arm64 --output dist/findmyminers-agent-linux-arm64",
    "build:all": "npm run build:win && npm run build:linux && npm run build:arm64"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  }
}
